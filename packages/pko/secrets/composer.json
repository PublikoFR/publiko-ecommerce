{
    "name": "pko/lunar-secrets",
    "description": "Gestion unifiée des credentials (env ou base de données) pour les modules PKO.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "pko/lunar-storefront-cms": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Pko\\Secrets\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\Secrets\\SecretsServiceProvider"
            ],
            "aliases": {
                "Secrets": "Pko\\Secrets\\Facades\\Secrets"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
