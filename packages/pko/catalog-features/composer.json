{
    "name": "pko/lunar-catalog-features",
    "description": "Caractéristiques produits filtrables (attributs structurés) pour Lunar.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0",
        "filament/filament": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pko\\CatalogFeatures\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\CatalogFeatures\\CatalogFeaturesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
