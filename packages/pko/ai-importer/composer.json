{
    "name": "pko/lunar-ai-importer",
    "description": "Pipeline d'import produits Lunar via LLM : Excel multi-feuilles + actions chaînées + staging.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "filament/filament": "^3.0",
        "lunarphp/lunar": "^1.0",
        "phpoffice/phpspreadsheet": "^2.0 || ^3.0",
        "pko/lunar-ai-core": "@dev",
        "pko/lunar-catalog-features": "@dev",
        "pko/lunar-product-videos": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Pko\\AiImporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\AiImporter\\AiImporterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
