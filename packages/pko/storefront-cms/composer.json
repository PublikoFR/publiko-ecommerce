{
    "name": "pko/lunar-storefront-cms",
    "description": "CMS unifié multi-post-type + médiathèque admin + pages marque pour Lunar.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0",
        "filament/filament": "^3.0",
        "livewire/livewire": "^3.0",
        "pko/lunar-media-core": "@dev",
        "pko/lunar-page-builder": "@dev"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "Pko\\StorefrontCms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\StorefrontCms\\StorefrontCmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
