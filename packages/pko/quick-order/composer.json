{
    "name": "pko/lunar-quick-order",
    "description": "Commande rapide B2B : saisie SKU + quantité en masse.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0",
        "livewire/livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pko\\QuickOrder\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\QuickOrder\\QuickOrderServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
