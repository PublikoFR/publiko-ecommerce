{
    "name": "pko/product-videos",
    "description": "Vidéos produit multi-provider (YouTube, Vimeo, Dailymotion, MP4) pour Lunar.",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pko\\ProductVideos\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\ProductVideos\\ProductVideosServiceProvider"
            ]
        }
    }
}
