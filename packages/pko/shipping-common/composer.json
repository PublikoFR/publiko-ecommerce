{
    "name": "pko/lunar-shipping-common",
    "description": "Abstractions communes aux transporteurs dynamiques Lunar (Chronopost, Colissimo, etc.).",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0",
        "filament/filament": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pko\\ShippingCommon\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\ShippingCommon\\ShippingCommonServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
