{
    "name": "pko/lunar-storefront",
    "description": "Frontoffice B2B Lunar : pages produit/collection/recherche, add-to-cart, checkout.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "lunarphp/core": "^1.0",
        "livewire/livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pko\\Storefront\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pko\\Storefront\\StorefrontServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
