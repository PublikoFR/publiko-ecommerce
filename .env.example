APP_NAME="MDE Distribution"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://mde-laravel.localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mde
DB_USERNAME=mde
DB_PASSWORD=mde_password
DB_ROOT_PASSWORD=root_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=mde

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@mde-distribution.fr"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Docker user mapping (host UID/GID for the "sail" user inside the container)
UID=1000
GID=1000

# Lunar payments — default payment type handle (see config/lunar/payments.php)
PAYMENTS_TYPE=cash-in-hand

# Stripe (lunarphp/stripe)
STRIPE_PK=
STRIPE_SECRET=
LUNAR_STRIPE_WEBHOOK_SECRET=

# Chronopost (Mde\ShippingChronopost) — vides par défaut, renseigner en prod
CHRONOPOST_ACCOUNT=
CHRONOPOST_PASSWORD=
CHRONOPOST_SUB_ACCOUNT=

# Colissimo (Mde\ShippingColissimo) — vides par défaut, renseigner en prod
COLISSIMO_CONTRACT=
COLISSIMO_PASSWORD=
COLISSIMO_WSDL_URL=https://ws.colissimo.fr/sls-ws/SlsServiceWS?wsdl

# Adresse expéditeur MDE (partagée Chronopost + Colissimo) — valeurs de test
MDE_SHIPPER_NAME="MDE Distribution"
MDE_SHIPPER_STREET="12 rue des Artisans"
MDE_SHIPPER_ZIP="69007"
MDE_SHIPPER_CITY="Lyon"
MDE_SHIPPER_COUNTRY="FR"
MDE_SHIPPER_PHONE="0478000000"
MDE_SHIPPER_EMAIL="logistique@mde-distribution.fr"
